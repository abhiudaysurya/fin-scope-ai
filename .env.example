# FinScope AI - Environment Configuration

# Application
APP_NAME=FinScope AI
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://finscope:finscope_secret@localhost:5432/finscope_db
DATABASE_URL_SYNC=postgresql://finscope:finscope_secret@localhost:5432/finscope_db

# PostgreSQL
POSTGRES_USER=finscope
POSTGRES_PASSWORD=finscope_secret
POSTGRES_DB=finscope_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Model Configuration
MODEL_PATH=./models/artifacts
DEFAULT_MODEL=xgboost
MODEL_THRESHOLD=0.5

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/finscope.log

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
